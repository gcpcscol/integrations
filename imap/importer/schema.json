{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plakar Scaleway Block Storage Connector Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "location",
    "access_key",
    "secret_key",
    "project_id",
    "volume_id",
    "bucket"
  ],
  "properties": {
    "location": {
      "type": "string",
      "const": "scaleway+block://",
      "description": "Connector location identifier for Scaleway Block Storage"
    },
    "access_key": {
      "type": "string",
      "minLength": 1,
      "description": "Scaleway API access key"
    },
    "secret_key": {
      "type": "string",
      "minLength": 1,
      "description": "Scaleway API secret key"
    },
    "project_id": {
      "type": "string",
      "format": "uuid",
      "description": "Scaleway project ID"
    },
    "volume_id": {
      "type": "string",
      "format": "uuid",
      "description": "Scaleway block volume ID"
    },
    "bucket": {
      "type": "string",
      "minLength": 1,
      "description": "Bucket or logical container name used to store snapshot data"
    },
    "zone": {
      "type": "string",
      "description": "Scaleway zone (e.g. fr-par-1)",
      "pattern": "^[a-z]{2}-[a-z]+-[0-9]$"
    },
    "endpoint": {
      "type": "string",
      "format": "uri",
      "description": "Optional custom API endpoint"
    }
  }
}