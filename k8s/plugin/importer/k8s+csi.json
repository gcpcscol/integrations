{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plakar K8S Importer Connector Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "location",
    "kubeconfig",
    "volume_snapshot_class"
  ],
  "properties": {
    "location": {
      "type": "string",
      "minLength": 1,
      "description": "optional endpoint with optional namespace"
    },
    "kubeconfig": {
      "type": "string",
      "description": "Kube config content to use"
    },
    "volume_snapshot_class": {
      "type": "string",
      "description": "Volume snapshot class"
    },
    "kubelet_image": {
      "type": "string",
      "description": "Optional kubelet image to use"
    }
  }
}
