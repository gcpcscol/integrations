{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plakar K8S Importer Connector Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "location"
  ],
  "properties": {
    "location": {
      "type": "string",
      "minLength": 1,
      "description": "optional endpoint with optional namespace"
    },
    "kubeconfig_file": {
      "type": "string",
      "description": "optional path to a kube config file"
    },
    "kubeconfig": {
      "type": "string",
      "description": "optional kube config content to use"
    },
    "volume_snapshot_class": {
      "type": "string",
      "description": "Volume snapshot class"
    },
    "kubelet_image": {
      "type": "string",
      "description": "Kubelet image to use"
    }
  }
}
