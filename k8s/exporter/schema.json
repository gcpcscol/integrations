{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plakar K8S Exporter Connector Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "location"
  ],
  "properties": {
    "location": {
      "type": "string",
      "minLength": 1,
      "description": "ETCD server url"
    },
    "volume_snapshot_class": {
      "type": "string",
      "description": "Volume snapshot class"
    },
    "kubelet_image": {
      "type": "string",
      "description": "Kubelet image"
    }
  }
}
